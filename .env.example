
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory

# --- Backend ---
# Port the backend API is published on (host side).
BACKEND_PORT=8000
# Low-stock threshold for the dashboard.
LOW_STOCK_THRESHOLD=10
# Allowed CORS origins (comma-separated). Must include the frontend URL below.
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
# Port the frontend (nginx) is published on (host side).
FRONTEND_PORT=3000
# API URL baked into the frontend bundle at build time. This is hit by the
# user's browser, so it must be reachable from the host (the backend's
# published port), not the internal docker hostname.
VITE_API_URL=http://localhost:8000
